# Image generation (one or both — required for images mode)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: override the Gemini image model globally (config.imageModel takes precedence).
# Cheap iteration: gemini-2.5-flash-image (~$0.039/img). Best finals: gemini-3-pro-image-preview (~$0.134 @2K, $0.24 @4K).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Video generation (Plan 3 — not needed for brand-images mode)
# HF_API_KEY=
# HF_API_SECRET=

# Voiceover + transcription (Plan 3 — only needed for --render). OPENAI_API_KEY above is shared.
# ELEVENLABS_API_KEY=
